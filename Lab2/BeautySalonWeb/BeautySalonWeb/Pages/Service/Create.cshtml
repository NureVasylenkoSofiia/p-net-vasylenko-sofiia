@page
@model BeautySalonWeb.Pages.Service.CreateModel
@{
    ViewData["Title"] = "Додати послугу";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="m-0 fw-bold"><i class="bi bi-plus-circle"></i> Нова послуга салону</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Service.Name" class="form-label fw-bold">Назва послуги</label>
                            <input asp-for="Service.Name" class="form-control" placeholder="Наприклад: Манікюр" />
                            <span asp-validation-for="Service.Name" class="text-danger fs-7"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Service.Price" class="form-label fw-bold">Вартість (грн)</label>
                            <input asp-for="Service.Price" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="Service.Price" class="text-danger fs-7"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Service.Duration" class="form-label fw-bold">Тривалість (хв)</label>
                            <input asp-for="Service.Duration" class="form-control" type="number" />
                            <span asp-validation-for="Service.Duration" class="text-danger fs-7"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-page="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Назад</a>
                            <button type="submit" class="btn btn-primary px-4">Зберегти</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
