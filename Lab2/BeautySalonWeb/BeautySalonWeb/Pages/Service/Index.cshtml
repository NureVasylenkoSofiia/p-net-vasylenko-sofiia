@page
@model BeautySalonWeb.Pages.Service.IndexModel
@{
    ViewData["Title"] = "Прайс-лист послуг";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">
            <i class="bi bi-scissors"></i> Послуги салону
        </h2>
        <a asp-page="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Додати послугу
        </a>
    </div>

    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Назва послуги</th>
                        <th>Вартість</th>
                        <th>Тривалість</th>
                        <th class="text-end pe-4">Операції</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ServicesList != null && Model.ServicesList.Any())
                    {
                        @foreach (var item in Model.ServicesList)
                        {
                            <tr>
                                <td class="fw-bold text-secondary ps-4">@item.Name</td>
                                <td>
                                    <span class="badge bg-info text-dark fs-6">@item.Price.ToString("F2") грн</span>
                                </td>
                                <td>
                                    <i class="bi bi-clock-history text-muted"></i> @item.Duration хв
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">Редагувати</a>
                                        <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Видалити</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                <i class="bi bi-folder-x fs-3"></i> <br /> Прейскурант порожній. Додайте першу послугу!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
