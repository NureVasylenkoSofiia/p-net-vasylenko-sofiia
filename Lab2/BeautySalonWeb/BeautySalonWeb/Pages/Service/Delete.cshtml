@page "{id:int}"
@model BeautySalonWeb.Pages.Service.DeleteModel
@{
    ViewData["Title"] = "Видалити послугу";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="m-0 fw-bold"><i class="bi bi-exclamation-triangle"></i> Попередження!</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <p class="fs-5 text-secondary">Ви впевнені, що хочете видалити цю послугу безповоротно?</p>

                    <div class="bg-light p-3 rounded-3 mb-4 text-start border">
                        <div class="mb-2"><strong>Назва:</strong> @Model.Service.Name</div>
                        <div class="mb-2"><strong>Вартість:</strong> @Model.Service.Price.ToString("F2") грн</div>
                        <div><strong>Тривалість:</strong> @Model.Service.Duration хв</div>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="Service.Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-page="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Назад</a>
                            <button type="submit" class="btn btn-danger px-4">Так, видалити</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
