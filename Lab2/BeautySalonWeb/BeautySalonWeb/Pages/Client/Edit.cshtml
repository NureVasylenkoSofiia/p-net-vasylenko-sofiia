@page "{id:int}"
@model BeautySalonWeb.Pages.Client.EditModel
@{
    ViewData["Title"] = "Редагувати клієнта";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="m-0 fw-bold"><i class="bi bi-pencil-square"></i> Редагувати дані клієнта</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Client.Id" />

                        <div class="form-group mb-3">
                            <label asp-for="Client.FullName" class="form-label fw-bold">Повне ім'я</label>
                            <input asp-for="Client.FullName" class="form-control" />
                            <span asp-validation-for="Client.FullName" class="text-danger fs-7"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Client.Phone" class="form-label fw-bold">Телефон</label>
                            <input asp-for="Client.Phone" class="form-control" />
                            <span asp-validation-for="Client.Phone" class="text-danger fs-7"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-page="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Скасувати</a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold">Оновити</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
