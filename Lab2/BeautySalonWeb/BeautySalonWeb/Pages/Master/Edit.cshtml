@page "{id:int}"
@model BeautySalonWeb.Pages.Master.EditModel
@{
    ViewData["Title"] = "Профіль майстра";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="m-0 fw-bold"><i class="bi bi-person-vcard"></i> Картка майстра</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Master.Id" />

                        <div class="form-group mb-3">
                            <label asp-for="Master.FullName" class="form-label fw-bold">Повне ім'я (ПІБ)</label>
                            <input asp-for="Master.FullName" class="form-control" />
                            <span asp-validation-for="Master.FullName" class="text-danger fs-7"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Master.Phone" class="form-label fw-bold">Телефон</label>
                            <input asp-for="Master.Phone" class="form-control" />
                            <span asp-validation-for="Master.Phone" class="text-danger fs-7"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Master.Information" class="form-label fw-bold text-warning">
                                <i class="bi bi-info-circle-fill"></i> Системні відмітки (Аудит ЛБ 1)
                            </label>
                            <input asp-for="Master.Information" class="form-control bg-light text-secondary" readonly placeholder="Немає автоматичних відміток від тригера" />
                            <input type="hidden" asp-for="Master.Information" />
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-page="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Назад</a>
                            <button type="submit" class="btn btn-primary px-4">Зберегти зміни</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
\
